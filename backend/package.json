{
  "name": "habit-tracker-backend",
  "version": "1.0.0",
  "description": "Zenith Catalyst — Your AI-powered catalyst for peak performance and lasting habits.",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "esbuild src/server.ts src/worker/index.ts --bundle --platform=node --target=node20 --outdir=dist --format=esm --packages=external --banner:js=\"import{createRequire}from'module';const require=createRequire(import.meta.url);\"",
    "start": "node dist/server.js",
    "generate": "prisma generate",
    "migrate": "prisma migrate dev && prisma generate",
    "studio": "prisma studio",
    "db:push": "prisma db push && prisma generate",
    "seed": "tsx src/utils/seed.ts"
  },
  "dependencies": {
    "@google/genai": "^1.50.1",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "cron": "^4.4.0",
    "croner": "^10.0.1",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "express-rate-limit": "^7.5.1",
    "helmet": "^7.2.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.6",
    "pg": "^8.20.0",
    "pino": "^9.14.0",
    "pino-http": "^10.5.0",
    "pino-pretty": "^13.1.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/cron": "^2.0.1",
    "@types/express": "^4.17.25",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^20.14.0",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "esbuild": "^0.24.0",
    "prisma": "^7.8.0",
    "tsx": "^4.21.0",
    "typescript": "^5.4.5"
  }
}
