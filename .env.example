# ── Database ─────────────────────────────────────────────────────
# Local dev uses external DB; Docker Compose overrides this automatically
DATABASE_URL="postgresql://postgres:password@localhost:5432/zenithcatalyst?schema=public"
POSTGRES_DB=zenithcatalyst
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme_strong_password_here

# ── Redis ─────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT Secrets ──────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX
JWT_REFRESH_SECRET=REPLACE_WITH_ANOTHER_64_CHAR_RANDOM_HEX
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── AI (Google Gemini) ───────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=REPLACE_WITH_YOUR_GEMINI_API_KEY

# ── Server ───────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
LOG_LEVEL=info
FRONTEND_URL=http://localhost:5173
APP_PORT=80

# ── Email (SMTP / SendGrid / Resend) ─────────────────────────────
# For SendGrid: SMTP_HOST=smtp.sendgrid.net, SMTP_USER=apikey
# For Resend:   SMTP_HOST=smtp.resend.com, SMTP_USER=resend, SMTP_PASS=re_...
# For Gmail:    SMTP_HOST=smtp.gmail.com, SMTP_USER=you@gmail.com (use App Password)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=REPLACE_WITH_YOUR_SMTP_PASSWORD_OR_API_KEY
EMAIL_FROM=ZenithCatalyst <noreply@zenithcatalyst.app>
